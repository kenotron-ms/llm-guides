digraph qwen35_variant {
    // ── Graph globals ─────────────────────────────────────────────────────────
    label    = "Qwen3.5 \u2014 Variant Selector"
    labelloc = t
    rankdir  = TB
    fontname = "Helvetica"
    fontsize = 14
    bgcolor  = "#ffffff"
    nodesep  = 0.55
    ranksep  = 0.70

    // ── Default styles ────────────────────────────────────────────────────────
    node [fontname="Helvetica" fontsize=12 style="rounded,filled"
          fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#a1a1aa" arrowsize=0.8 penwidth=1.2]

    // ── Entry ─────────────────────────────────────────────────────────────────
    start [label="Qwen3.5 \u2014 pick a variant"
           shape=ellipse fillcolor="#f4f4f5" color="#09090b" fontcolor="#09090b" penwidth=2.0]

    // ── Decisions ─────────────────────────────────────────────────────────────
    d_vram [label="Available VRAM?"
            shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_pri  [label="Speed or\nquality?"
            shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_moe  [label="Dense or MoE?"
            shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]

    // ── Variant nodes ─────────────────────────────────────────────────────────
    // Workstation range
    v_27b  [label="27B Q4\n~14 GB  \u00b7  Strong dense, fits 16 GB VRAM"]
    v_35b  [label="35B-A3B Q4\n~18 GB  \u00b7  Fast MoE, 3B active params"]
    v_27q8 [label="27B Q8\n~27 GB  \u00b7  Near-lossless dense"]

    // High-capacity / multi-GPU
    v_122b [label="122B-A10B Q4\n~62 GB  \u00b7  Multi-GPU powerhouse"
             fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]

    // Datacenter — distinct amber-orange, not decision-diamond zinc
    v_397b [label="397B-A17B Q4\n~200 GB  \u00b7  Datacenter / multi-node"
             fillcolor="#ffedd5" color="#ea580c" fontcolor="#09090b"]

    // ── Edges ─────────────────────────────────────────────────────────────────
    start  -> d_vram
    d_vram -> v_27b  [label="14\u201316 GB"]
    d_vram -> d_pri  [label="18\u201324 GB"]
    d_pri  -> v_35b  [label="Fastest inference"]
    d_pri  -> v_27b  [label="Best quality"]
    d_vram -> d_moe  [label="24\u201348 GB"]
    d_moe  -> v_35b  [label="Speed"]
    d_moe  -> v_27q8 [label="Quality per GB"]
    d_vram -> v_122b [label="48\u201380 GB"]
    d_vram -> v_397b [label="200+ GB"]

    // ── Legend ────────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label     = "Legend"
        style     = "rounded,filled"
        fillcolor = "#f9fafb"
        color     = "#d4d4d8"
        fontname  = "Helvetica"
        fontsize  = 11

        node [width=2.4 height=0.38 margin="0.12,0.07"]

        lg_hi  [label="Recommended \u2014 high-capacity pick (48\u201380 GB)"
                fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
        lg_std [label="Standard workstation variant"
                fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b"]
        lg_dc  [label="Datacenter / multi-node \u2014 200+ GB required"
                fillcolor="#ffedd5" color="#ea580c" fontcolor="#09090b"]

        lg_hi  -> lg_std [style=invis]
        lg_std -> lg_dc  [style=invis]
    }
}
