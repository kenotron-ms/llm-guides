digraph vllm_decision {
    // ── Graph globals ─────────────────────────────────────────────────────────
    label    = "vLLM vs llama.cpp \u2014 Serving Decision"
    labelloc = t
    rankdir  = TB
    fontname = "Helvetica"
    fontsize = 14
    bgcolor  = "#ffffff"
    nodesep  = 0.55
    ranksep  = 0.70

    // ── Default styles ────────────────────────────────────────────────────────
    node [fontname="Helvetica" fontsize=12 style="rounded,filled"
          fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#a1a1aa" arrowsize=0.8 penwidth=1.2]

    // ── Entry ─────────────────────────────────────────────────────────────────
    start [label="Need an LLM server?"
           shape=ellipse fillcolor="#f4f4f5" color="#09090b" fontcolor="#09090b" penwidth=2.0]

    // ── Decisions ─────────────────────────────────────────────────────────────
    d_concur [label="Multiple concurrent\nusers?"
              shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_gpu    [label="CUDA / ROCm\nproduction GPU?"
              shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_thru   [label="Max throughput /\nbatching needed?"
              shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_gguf   [label="GGUF quantized\nmodel?"
              shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]

    // ── Backend results ───────────────────────────────────────────────────────
    vl [label="vLLM"
        fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
    lc [label="llama.cpp"]

    // ── Edges ─────────────────────────────────────────────────────────────────
    start    -> d_concur
    d_concur -> d_gpu  [label="Yes"]
    d_gpu    -> vl     [label="Yes"]
    d_gpu    -> lc     [label="No"]
    d_concur -> d_thru [label="No"]
    d_thru   -> vl     [label="Yes"]
    d_thru   -> d_gguf [label="No"]
    d_gguf   -> lc     [label="Yes \u2014 GGUF model"]
    d_gguf   -> vl     [label="No \u2014 BF16 / FP8"]

    // ── Legend ────────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label     = "Legend"
        style     = "rounded,filled"
        fillcolor = "#f9fafb"
        color     = "#d4d4d8"
        fontname  = "Helvetica"
        fontsize  = 11

        node [width=2.4 height=0.38 margin="0.12,0.07"]

        lg_vllm [label="vLLM \u2014 production multi-user serving"
                 fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
        lg_lc   [label="llama.cpp \u2014 single-user / GGUF / edge"
                 fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b"]

        lg_vllm -> lg_lc [style=invis]
    }
}
