digraph agent_model_selector {
    // ── Graph globals ─────────────────────────────────────────────────────────
    label    = "Agent Model Selector"
    labelloc = t
    rankdir  = TB
    fontname = "Helvetica"
    fontsize = 14
    bgcolor  = "#ffffff"
    nodesep  = 0.55
    ranksep  = 0.70

    // ── Default styles ────────────────────────────────────────────────────────
    node [fontname="Helvetica" fontsize=12 style="rounded,filled"
          fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#a1a1aa" arrowsize=0.8 penwidth=1.2]

    // ── Entry ─────────────────────────────────────────────────────────────────
    start [label="Agent task type?"
           shape=ellipse fillcolor="#f4f4f5" color="#09090b" fontcolor="#09090b" penwidth=2.0]

    // ── Decisions ─────────────────────────────────────────────────────────────
    d_code   [label="Agentic coding?"
              shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_reason [label="Deep reasoning\nor math?"
              shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_budget [label="Can afford\nslower inference?"
              shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_vision [label="Vision /\nmultimodal?"
              shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_ram    [label="RAM \u2264 8 GB?"
              shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]

    // ── Model recommendations ─────────────────────────────────────────────────
    // Coding specialist — top pick
    m_q36  [label="Qwen3.6 35B-A3B\nSWE-bench 73.4%  \u00b7  Thinking ON"
             fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]

    // Thinking / reasoning — top pick
    m_q35t [label="Qwen3.5 35B-A3B or 27B\nThinking ON"
             fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]

    // General-purpose MoE (standard)
    m_g4   [label="Gemma 4 26B-A4B or 31B"]

    // Vision-capable (standard)
    m_g4v  [label="Gemma 4 26B-A4B  or\nQwen3.5 27B  (vision via mmproj)"]

    // Edge / RAM-constrained
    m_g4e  [label="Gemma 4 E4B"
             fillcolor="#ede9fe" color="#7c3aed" fontcolor="#09090b"]

    // Audio capability annotation
    note_audio [label="Audio supported\non E2B / E4B"
                shape=note style="filled"
                fillcolor="#f9fafb" color="#d4d4d8" fontcolor="#71717a" fontsize=10]

    // ── Edges ─────────────────────────────────────────────────────────────────
    start    -> d_code
    d_code   -> m_q36   [label="Yes"]
    d_code   -> d_reason [label="No"]
    d_reason -> d_budget [label="Yes"]
    d_budget -> m_q35t  [label="Yes"]
    d_budget -> m_g4    [label="No"]
    d_reason -> d_vision [label="No"]
    d_vision -> m_g4v   [label="Yes"]
    d_vision -> d_ram   [label="No"]
    d_ram    -> m_g4e   [label="Yes"]
    d_ram    -> m_g4    [label="No"]

    // Audio annotation — dashed, no arrowhead
    m_g4e -> note_audio [style=dashed arrowhead=none color="#d4d4d8" penwidth=1.0]

    // ── Legend ────────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label     = "Legend"
        style     = "rounded,filled"
        fillcolor = "#f9fafb"
        color     = "#d4d4d8"
        fontname  = "Helvetica"
        fontsize  = 11

        node [width=2.2 height=0.38 margin="0.12,0.07"]

        lg_top  [label="Top specialist pick \u2014 benchmark-backed"
                 fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
        lg_std  [label="General-purpose pick"
                 fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b"]
        lg_edge [label="Edge / RAM-constrained pick"
                 fillcolor="#ede9fe" color="#7c3aed" fontcolor="#09090b"]

        lg_top  -> lg_std  [style=invis]
        lg_std  -> lg_edge [style=invis]
    }
}
