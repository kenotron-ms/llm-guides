digraph rocm_backend {
    // ── Graph globals ──────────────────────────────────────────────────────────
    label    = "AMD GPU \u2014 ROCm Backend Support Matrix"
    labelloc = t
    rankdir  = TB
    fontname = "Helvetica"
    fontsize = 14
    bgcolor  = "#FFFFFF"
    nodesep  = 0.60
    ranksep  = 0.75

    // ── Default styles ─────────────────────────────────────────────────────────
    node [fontname="Helvetica" fontsize=12 style="rounded,filled"
          fillcolor="#EEF2FF" color="#3949AB" fontcolor="#1A237E" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#455A64" arrowsize=0.85 penwidth=1.3]

    // ── Entry ──────────────────────────────────────────────────────────────────
    start [label="AMD GPU"
           shape=ellipse fillcolor="#E3F2FD" color="#1565C0" fontcolor="#0D47A1"]

    // ── Decision ───────────────────────────────────────────────────────────────
    d_arch [label="Architecture?"
            shape=diamond fillcolor="#FFF8E1" color="#E65100" fontcolor="#BF360C"]

    // ── Architecture tiers ─────────────────────────────────────────────────────
    arch_cdna3 [label="CDNA3+\nMI300X / MI325X\nMI350X / MI355X"]
    arch_cdna2 [label="CDNA2\nMI250X / MI210"]
    arch_rdna3 [label="RDNA3\nRX 7900 XTX / XT\nRX 7800 / 7700 XT"]
    arch_rdna2 [label="RDNA2\nRX 6900 / 6800\nRX 6700 / 6600 XT"]

    // ── Support-tier result nodes ──────────────────────────────────────────────
    // Full support
    tier_full [label="vLLM \u2713   llama.cpp \u2713   Ollama \u2713\nFull stack support"
               fillcolor="#E8F5E9" color="#2E7D32" fontcolor="#1B5E20"]

    // Partial — vLLM limited
    tier_part [label="vLLM \u26a0   llama.cpp \u2713   Ollama \u2713\nLimited vLLM support"
               fillcolor="#FFF3E0" color="#E65100" fontcolor="#BF360C"]

    // vLLM not supported
    tier_none [label="vLLM \u2717   llama.cpp \u2713   Ollama \u2713\nvLLM unsupported on consumer RDNA"
               fillcolor="#FFEBEE" color="#C62828" fontcolor="#B71C1C"]

    // ── Edges ──────────────────────────────────────────────────────────────────
    start      -> d_arch
    d_arch     -> arch_cdna3 [label="CDNA3+"]
    d_arch     -> arch_cdna2 [label="CDNA2"]
    d_arch     -> arch_rdna3 [label="RDNA3"]
    d_arch     -> arch_rdna2 [label="RDNA2"]
    arch_cdna3 -> tier_full
    arch_cdna2 -> tier_part
    arch_rdna3 -> tier_none
    arch_rdna2 -> tier_none

    // ── Legend ─────────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label     = "Legend"
        style     = "rounded,filled"
        fillcolor = "#F5F5F5"
        color     = "#B0BEC5"
        fontname  = "Helvetica"
        fontsize  = 11

        node [width=2.1 height=0.38 margin="0.12,0.07"]

        lg_entry [label="Entry"                shape=ellipse
                  fillcolor="#E3F2FD" color="#1565C0" fontcolor="#0D47A1"]
        lg_dec   [label="Decision"             shape=diamond
                  fillcolor="#FFF8E1" color="#E65100" fontcolor="#BF360C"]
        lg_full  [label="Full stack support"
                  fillcolor="#E8F5E9" color="#2E7D32" fontcolor="#1B5E20"]
        lg_part  [label="Partial support (vLLM limited)"
                  fillcolor="#FFF3E0" color="#E65100" fontcolor="#BF360C"]
        lg_none  [label="vLLM unsupported"
                  fillcolor="#FFEBEE" color="#C62828" fontcolor="#B71C1C"]

        lg_entry -> lg_dec  [style=invis]
        lg_dec   -> lg_full [style=invis]
        lg_full  -> lg_part [style=invis]
        lg_part  -> lg_none [style=invis]
    }
}
