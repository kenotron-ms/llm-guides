digraph backend_selector {
    // ── Graph globals ─────────────────────────────────────────────────────────
    label    = "LLM Backend Selector"
    labelloc = t
    rankdir  = TB
    fontname = "Helvetica"
    fontsize = 14
    bgcolor  = "#ffffff"
    nodesep  = 0.55
    ranksep  = 0.70

    // ── Default styles ────────────────────────────────────────────────────────
    node [fontname="Helvetica" fontsize=12 style="rounded,filled"
          fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#a1a1aa" arrowsize=0.8 penwidth=1.2]

    // ── Entry ─────────────────────────────────────────────────────────────────
    start [label="What do I need?"
           shape=ellipse fillcolor="#f4f4f5" color="#09090b" fontcolor="#09090b" penwidth=2.0]

    // ── Decisions ─────────────────────────────────────────────────────────────
    d_gui  [label="GUI required?"
            shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_prod [label="Multi-user /\nproduction?"
            shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_gpu  [label="NVIDIA or\nMI300X+?"
            shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_team [label="Quick setup /\nteam serving?"
            shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_ctrl [label="Need per-layer\nCPU offload?"
            shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]

    // ── Backend results ───────────────────────────────────────────────────────
    lms [label="LM Studio"
         fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
    vl  [label="vLLM"
         fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
    ol  [label="Ollama"]
    lc  [label="llama.cpp"]

    // ── Edges ─────────────────────────────────────────────────────────────────
    start  -> d_gui
    d_gui  -> lms    [label="Yes"]
    d_gui  -> d_prod [label="No"]
    d_prod -> d_gpu  [label="Yes"]
    d_gpu  -> vl     [label="Yes"]
    d_gpu  -> lc     [label="No"]
    d_prod -> d_team [label="No"]
    d_team -> ol     [label="Yes"]
    d_team -> d_ctrl [label="No"]
    d_ctrl -> lc     [label="Yes"]
    d_ctrl -> ol     [label="No"]

    // ── Legend ────────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label     = "Legend"
        style     = "rounded,filled"
        fillcolor = "#f9fafb"
        color     = "#d4d4d8"
        fontname  = "Helvetica"
        fontsize  = 11

        node [width=2.3 height=0.38 margin="0.12,0.07"]

        lg_prod [label="Recommended — production or top pick"
                 fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
        lg_std  [label="General-purpose backend"
                 fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b"]

        lg_prod -> lg_std [style=invis]
    }
}
