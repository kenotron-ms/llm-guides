digraph local_cloud_fallback {
    // ── Graph globals ─────────────────────────────────────────────────────────
    label    = "Agent Request \u2014 Local \u2192 Cloud Fallback Routing"
    labelloc = t
    rankdir  = TB
    fontname = "Helvetica"
    fontsize = 14
    bgcolor  = "#ffffff"
    nodesep  = 0.55
    ranksep  = 0.70

    // ── Default styles ────────────────────────────────────────────────────────
    node [fontname="Helvetica" fontsize=12 style="rounded,filled"
          fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#a1a1aa" arrowsize=0.8 penwidth=1.2]

    // ── Entry / Exit ──────────────────────────────────────────────────────────
    agent  [label="Agent request"
            shape=ellipse fillcolor="#f4f4f5" color="#09090b" fontcolor="#09090b" penwidth=2.0]
    result [label="Return response"
            shape=ellipse fillcolor="#f4f4f5" color="#09090b" fontcolor="#09090b" penwidth=2.0]

    // ── Decisions ─────────────────────────────────────────────────────────────
    d_probe    [label="Probe local endpoint\nlocalhost:port/health"
                shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_fallback [label="Fallback\nenabled?"
                shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]

    // ── Routing dispatch (process step, not decision) ─────────────────────────
    d_cloud [label="Select cloud API"
             fillcolor="#f4f4f5" color="#52525b" fontcolor="#09090b"]

    // ── Local inference stack ─────────────────────────────────────────────────
    local [label="Route to local model\nllama.cpp / Ollama / vLLM"
           fillcolor="#dcfce7" color="#16a34a" fontcolor="#09090b"]

    // ── Error terminal ────────────────────────────────────────────────────────
    err [label="Return error"
         fillcolor="#fee2e2" color="#dc2626" fontcolor="#09090b"]

    // ── Cloud API options (parallelogram = external system) ───────────────────
    c_coding [label="DeepSeek V3 / Kimi K2.5\nCoding / agents"
               shape=parallelogram
               fillcolor="#ffedd5" color="#ea580c" fontcolor="#09090b"]
    c_reason [label="DeepSeek R1 / Kimi K2.5\nReasoning / math"
               shape=parallelogram
               fillcolor="#ffedd5" color="#ea580c" fontcolor="#09090b"]
    c_cost   [label="Mistral Small 3.2 / GLM-4.5 Air\nCost-sensitive"
               shape=parallelogram
               fillcolor="#ffedd5" color="#ea580c" fontcolor="#09090b"]

    // ── Edges ─────────────────────────────────────────────────────────────────
    agent      -> d_probe
    d_probe    -> local      [label="Responds in time"]
    d_probe    -> d_fallback [label="Timeout / error"]
    d_fallback -> d_cloud    [label="Yes"]
    d_fallback -> err        [label="No"]
    d_cloud    -> c_coding   [label="Coding / agents"]
    d_cloud    -> c_reason   [label="Reasoning / math"]
    d_cloud    -> c_cost     [label="Cost-sensitive"]

    local    -> result
    c_coding -> result
    c_reason -> result
    c_cost   -> result

    // ── Legend ────────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label     = "Legend"
        style     = "rounded,filled"
        fillcolor = "#f9fafb"
        color     = "#d4d4d8"
        fontname  = "Helvetica"
        fontsize  = 11

        node [width=2.4 height=0.38 margin="0.12,0.07"]

        lg_local [label="Local inference \u2014 preferred path"
                  fillcolor="#dcfce7" color="#16a34a" fontcolor="#09090b"]
        lg_cloud [label="Cloud API fallback \u2014 external, task-specific"
                  shape=parallelogram
                  fillcolor="#ffedd5" color="#ea580c" fontcolor="#09090b"]
        lg_err   [label="Error \u2014 fallback disabled"
                  fillcolor="#fee2e2" color="#dc2626" fontcolor="#09090b"]

        lg_local -> lg_cloud [style=invis]
        lg_cloud -> lg_err   [style=invis]
    }
}
