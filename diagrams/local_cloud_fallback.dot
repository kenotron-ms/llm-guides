digraph local_cloud_fallback {
    // ── Graph globals ──────────────────────────────────────────────────────────
    label    = "Agent Request \u2014 Local \u2192 Cloud Fallback Routing"
    labelloc = t
    rankdir  = TB
    fontname = "Helvetica"
    fontsize = 14
    bgcolor  = "#FFFFFF"
    nodesep  = 0.55
    ranksep  = 0.70

    // ── Default styles ─────────────────────────────────────────────────────────
    node [fontname="Helvetica" fontsize=12 style="rounded,filled"
          fillcolor="#EEF2FF" color="#3949AB" fontcolor="#1A237E" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#455A64" arrowsize=0.85 penwidth=1.3]

    // ── Entry / Exit ───────────────────────────────────────────────────────────
    agent  [label="Agent request"
            shape=ellipse fillcolor="#E3F2FD" color="#1565C0" fontcolor="#0D47A1"]
    result [label="Return response"
            shape=ellipse fillcolor="#E3F2FD" color="#1565C0" fontcolor="#0D47A1"]

    // ── Decisions ──────────────────────────────────────────────────────────────
    d_probe    [label="Probe local endpoint\nlocalhost:port/health"
                shape=diamond fillcolor="#FFF8E1" color="#E65100" fontcolor="#BF360C"]
    d_fallback [label="Fallback\nenabled?"
                shape=diamond fillcolor="#FFF8E1" color="#E65100" fontcolor="#BF360C"]
    d_cloud    [label="Select cloud API"
                shape=diamond fillcolor="#FFF8E1" color="#E65100" fontcolor="#BF360C"]

    // ── Local inference stack ──────────────────────────────────────────────────
    local [label="Route to local model\nllama.cpp / Ollama / vLLM"
           fillcolor="#E8F5E9" color="#2E7D32" fontcolor="#1B5E20"]

    // ── Error terminal ─────────────────────────────────────────────────────────
    err [label="Return error"
         fillcolor="#FFEBEE" color="#C62828" fontcolor="#B71C1C"]

    // ── Cloud API options (parallelogram = external system) ────────────────────
    c_coding [label="DeepSeek V3 / Kimi K2.5\nCoding / agents"
               shape=parallelogram
               fillcolor="#FFFDE7" color="#F57F17" fontcolor="#E65100"]
    c_reason [label="DeepSeek R1 / Kimi K2.5\nReasoning / math"
               shape=parallelogram
               fillcolor="#FFFDE7" color="#F57F17" fontcolor="#E65100"]
    c_cost   [label="Mistral Small 3.2 / GLM-4.5 Air\nCost-sensitive"
               shape=parallelogram
               fillcolor="#FFFDE7" color="#F57F17" fontcolor="#E65100"]

    // ── Edges ──────────────────────────────────────────────────────────────────
    agent      -> d_probe
    d_probe    -> local      [label="Responds in time"]
    d_probe    -> d_fallback [label="Timeout / error"]
    d_fallback -> d_cloud    [label="Yes"]
    d_fallback -> err        [label="No"]
    d_cloud    -> c_coding   [label="Coding / agents"]
    d_cloud    -> c_reason   [label="Reasoning / math"]
    d_cloud    -> c_cost     [label="Cost-sensitive"]

    local    -> result
    c_coding -> result
    c_reason -> result
    c_cost   -> result

    // ── Legend ─────────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label     = "Legend"
        style     = "rounded,filled"
        fillcolor = "#F5F5F5"
        color     = "#B0BEC5"
        fontname  = "Helvetica"
        fontsize  = 11

        node [width=2.1 height=0.38 margin="0.12,0.07"]

        lg_entry [label="Entry / Exit"            shape=ellipse
                  fillcolor="#E3F2FD" color="#1565C0" fontcolor="#0D47A1"]
        lg_dec   [label="Decision / probe"        shape=diamond
                  fillcolor="#FFF8E1" color="#E65100" fontcolor="#BF360C"]
        lg_local [label="Local inference stack"
                  fillcolor="#E8F5E9" color="#2E7D32" fontcolor="#1B5E20"]
        lg_cloud [label="Cloud API (external)"    shape=parallelogram
                  fillcolor="#FFFDE7" color="#F57F17" fontcolor="#E65100"]
        lg_err   [label="Error state"
                  fillcolor="#FFEBEE" color="#C62828" fontcolor="#B71C1C"]

        lg_entry -> lg_dec   [style=invis]
        lg_dec   -> lg_local [style=invis]
        lg_local -> lg_cloud [style=invis]
        lg_cloud -> lg_err   [style=invis]
    }
}
