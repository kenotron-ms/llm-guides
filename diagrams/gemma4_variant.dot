digraph gemma4_variant {
    // ── Graph globals ─────────────────────────────────────────────────────────
    label    = "Gemma 4 \u2014 Variant Selector"
    labelloc = t
    rankdir  = TB
    fontname = "Helvetica"
    fontsize = 14
    bgcolor  = "#ffffff"
    nodesep  = 0.55
    ranksep  = 0.70

    // ── Default styles ────────────────────────────────────────────────────────
    node [fontname="Helvetica" fontsize=12 style="rounded,filled"
          fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#a1a1aa" arrowsize=0.8 penwidth=1.2]

    // ── Entry ─────────────────────────────────────────────────────────────────
    start [label="Which Gemma 4\nvariant fits\nmy hardware?"
           shape=ellipse fillcolor="#f4f4f5" color="#09090b" fontcolor="#09090b" penwidth=2.0]

    // ── Decisions ─────────────────────────────────────────────────────────────
    d_ram [label="Available RAM / VRAM?"
           shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_moe [label="Dense or MoE?"
           shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]

    // ── Variant nodes ─────────────────────────────────────────────────────────
    // Edge / ultra-low RAM
    v_e2b  [label="E2B Q4\n~3 GB  \u00b7  Phone / Pi / edge"
             fillcolor="#ede9fe" color="#7c3aed" fontcolor="#09090b"]
    v_e4b4 [label="E4B Q4\n~5 GB  \u00b7  Laptop / 8 GB RAM"
             fillcolor="#ede9fe" color="#7c3aed" fontcolor="#09090b"]

    // Standard desktop range
    v_e4b8 [label="E4B Q8\n~7.5 GB  \u00b7  Desktop, near-lossless"]
    v_m26  [label="26B-A4B Q4\n~16 GB  \u00b7  Best speed / quality balance"]

    // Recommended / high-quality
    v_m31  [label="31B Q4\n~17 GB  \u00b7  Highest quality"
             fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
    v_m31h [label="31B Q8 / BF16\n~34 GB  \u00b7  Near-lossless"
             fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]

    // ── Edges ─────────────────────────────────────────────────────────────────
    start  -> d_ram
    d_ram  -> v_e2b  [label="< 5 GB"]
    d_ram  -> v_e4b4 [label="5\u20138 GB"]
    d_ram  -> v_e4b8 [label="8\u201315 GB"]
    d_ram  -> v_m26  [label="16\u201320 GB"]
    d_ram  -> d_moe  [label="20\u201324 GB"]
    d_moe  -> v_m26  [label="Speed + efficiency"]
    d_moe  -> v_m31  [label="Max quality"]
    d_ram  -> v_m31h [label="48+ GB"]

    // ── Legend ────────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label     = "Legend"
        style     = "rounded,filled"
        fillcolor = "#f9fafb"
        color     = "#d4d4d8"
        fontname  = "Helvetica"
        fontsize  = 11

        node [width=2.3 height=0.38 margin="0.12,0.07"]

        lg_best [label="Recommended \u2014 highest quality when VRAM allows"
                 fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
        lg_std  [label="Standard desktop \u2014 good quality / VRAM balance"
                 fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b"]
        lg_edge [label="Edge / low-RAM \u2014 ultra-low memory budget"
                 fillcolor="#ede9fe" color="#7c3aed" fontcolor="#09090b"]

        lg_best -> lg_std  [style=invis]
        lg_std  -> lg_edge [style=invis]
    }
}
