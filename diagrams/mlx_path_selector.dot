digraph mlx_path_selector {
    // ── Graph globals ─────────────────────────────────────────────────────────
    label    = "Apple Silicon \u2014 MLX Inference Path Selector"
    labelloc = t
    rankdir  = TB
    fontname = "Helvetica"
    fontsize = 14
    bgcolor  = "#ffffff"
    nodesep  = 0.55
    ranksep  = 0.70

    // ── Default styles ────────────────────────────────────────────────────────
    node [fontname="Helvetica" fontsize=12 style="rounded,filled"
          fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b" penwidth=1.5]
    edge [fontname="Helvetica" fontsize=10 color="#a1a1aa" arrowsize=0.8 penwidth=1.2]

    // ── Entry ─────────────────────────────────────────────────────────────────
    start [label="Apple Silicon inference"
           shape=ellipse fillcolor="#f4f4f5" color="#09090b" fontcolor="#09090b" penwidth=2.0]

    // ── Decisions ─────────────────────────────────────────────────────────────
    d_input [label="Model input type?"
             shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]
    d_pri   [label="Optimize for?"
             shape=diamond fillcolor="#f4f4f5" color="#71717a" fontcolor="#09090b"]

    // ── Backend results ───────────────────────────────────────────────────────
    mlx_vlm  [label="mlx_vlm"
               fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
    ol_metal [label="Ollama  (Metal)"]
    lc_metal [label="llama.cpp  (Metal)"]

    // ── Throughput reference annotations ──────────────────────────────────────
    ref_mlx [label="\u223535\u201355 tok/s\n(M3/M4 Max \u00b7 26B Q4)"
              shape=note style="filled"
              fillcolor="#f9fafb" color="#d4d4d8" fontcolor="#71717a" fontsize=10]
    ref_lc  [label="\u223525\u201340 tok/s\n(M3/M4 Max \u00b7 26B Q4)"
              shape=note style="filled"
              fillcolor="#f9fafb" color="#d4d4d8" fontcolor="#71717a" fontsize=10]
    ref_ol  [label="\u223520\u201335 tok/s\n(M3/M4 Max \u00b7 26B Q4)"
              shape=note style="filled"
              fillcolor="#f9fafb" color="#d4d4d8" fontcolor="#71717a" fontsize=10]

    // ── Edges ─────────────────────────────────────────────────────────────────
    start    -> d_input
    d_input  -> mlx_vlm  [label="Vision / multimodal"]
    d_input  -> d_pri    [label="Text only"]
    d_pri    -> mlx_vlm  [label="Max speed (tok/s)"]
    d_pri    -> ol_metal [label="Easy setup"]
    d_pri    -> lc_metal [label="GGUF / full control"]

    // Annotation edges — dashed, no arrowhead
    mlx_vlm  -> ref_mlx [style=dashed arrowhead=none color="#d4d4d8" penwidth=1.0]
    lc_metal -> ref_lc  [style=dashed arrowhead=none color="#d4d4d8" penwidth=1.0]
    ol_metal -> ref_ol  [style=dashed arrowhead=none color="#d4d4d8" penwidth=1.0]

    // ── Legend ────────────────────────────────────────────────────────────────
    subgraph cluster_legend {
        label     = "Legend"
        style     = "rounded,filled"
        fillcolor = "#f9fafb"
        color     = "#d4d4d8"
        fontname  = "Helvetica"
        fontsize  = 11

        node [width=2.3 height=0.38 margin="0.12,0.07"]

        lg_fast [label="Fastest path \u2014 max tok/s on Apple Silicon"
                 fillcolor="#dbeafe" color="#2563eb" fontcolor="#09090b"]
        lg_std  [label="General-purpose Metal backend"
                 fillcolor="#fafafa" color="#d4d4d8" fontcolor="#09090b"]
        lg_perf [label="Throughput ref (M3/M4 Max \u00b7 26B Q4)"
                 shape=note style="filled"
                 fillcolor="#f9fafb" color="#d4d4d8" fontcolor="#71717a"]

        lg_fast -> lg_std  [style=invis]
        lg_std  -> lg_perf [style=invis]
    }
}
